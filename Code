char data;
int relay = 8;

void setup() {
  Serial.begin(9600);
  pinMode(relay, OUTPUT);
}

void loop() {
  if (Serial.available()) {
    data = Serial.read();

    if (data == '1') {
      digitalWrite(relay, HIGH); // ON
    }
    else if (data == '0') {
      digitalWrite(relay, LOW);  // OFF
    }
  }
}
